{
  "name": "@teamgaga/miniapp-jssdk",
  "version": "0.1.5",
  "description": "TeamGaga MiniApp JavaScript SDK for Flutter WebView containers",
  "keywords": [
    "jssdk",
    "miniapp",
    "sdk",
    "teamgaga",
    "webview"
  ],
  "homepage": "https://github.com/AlbertaMoulton/sdk-js#readme",
  "bugs": {
    "url": "https://github.com/AlbertaMoulton/sdk-js/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlbertaMoulton/sdk-js.git",
    "directory": "libs/miniapp-jssdk"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.iife.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "default": "./dist/index.iife.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "pnpm run clean && rollup -c && tsc -p tsconfig.json --emitDeclarationOnly",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "pack:check": "pnpm run build && pnpm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "test": "vp test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@babel/preset-env": "latest",
    "@rollup/plugin-babel": "latest",
    "@rollup/plugin-terser": "latest",
    "@rollup/plugin-typescript": "latest",
    "rollup": "latest",
    "tslib": "latest",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
